@page "/Documentation"

@using AnglingClubShared.DTOs
@using AnglingClubShared.Extensions;
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Inputs
@using Microsoft.AspNetCore.Components.QuickGrid

@inherits RazorComponentBase;

<AuthorizationRequired>
    <div class="page-header">
        <h3>Documentation</h3>
    </div>

    @if (!CurrentUser.Secretary)
    {
        <b>You are not authorised to see this page</b>
    }
    else
    {
        <p>
            Browse and manage Club Documentation
        </p>

        <BusyIndicator IsReady="DataLoaded" />

        @if (DataLoaded)
        {
            <div class="documentation-page">
                <div class="documentation-tree-panel">
                    <div class="documentation-toolbar">
                        <SfTextBox Placeholder="New folder name" @bind-Value="NewFolderName" Width="190px"></SfTextBox>
                        <SfButton CssClass="e-primary" OnClick="CreateFolderAsync">
                            <i class="fa-solid fa-folder-plus" /> Add Folder
                        </SfButton>
                    </div>

                    <SfTreeView TValue="DocumentationTreeNode" @bind-SelectedNodes="SelectedTreeNodes">
                        <TreeViewFieldsSettings TValue="DocumentationTreeNode"
                                               Id="Id"
                                               ParentID="ParentId"
                                               DataSource="TreeNodes"
                                               Text="Name"
                                               HasChildren="HasChildren"
                                               IconCss="IconCss"
                                               Expanded="Expanded">
                        </TreeViewFieldsSettings>
                        <TreeViewEvents TValue="DocumentationTreeNode" NodeClicked="OnFolderClicked"></TreeViewEvents>
                    </SfTreeView>
                </div>

                <div class="documentation-files-panel">
                    <div class="documentation-files-header">
                        <h4>Files in: @SelectedFolderLabel</h4>
                    </div>

                    <SfUploader AutoUpload="true"
                                AllowMultiple="false"
                                MaxFileSize="20971520"
                                EnableHtmlSanitizer="true">
                        <UploaderEvents ValueChange="UploadHandler"></UploaderEvents>
                    </SfUploader>

                    @if (FilesInSelectedFolder.Any())
                    {
                        <QuickGrid Items="FilesInSelectedFolder.AsQueryable()" Class="bdac-table no-click">
                            <PropertyColumn Property="x => x.FileName" Title="File name" />
                            <TemplateColumn Title="Created" >
                                <span style="padding-left: 10px;">@((context.CreatedUtc.ToLocalTime()).BdacDateTime())</span>
                            </TemplateColumn>
                            <TemplateColumn Title="Download" Align="Align.Center">
                                <SfButton CssClass="grid-action-btn"
                                          IconCss="fa-solid fa-download"
                                          Title="Download"
                                          OnClick="@(async () => await DownloadAsync(context))" />
                            </TemplateColumn>
                        </QuickGrid>
                    }
                    else
                    {
                        <p>No files in this folder.</p>
                    }
                </div>
            </div>
        }
    }
</AuthorizationRequired>
